paths:
{{- range .ContextEntities}}
  {{$.BasePath}}/{{.SnakeName}}s:
    description: >-
      The REST endpoint/path used to list zero or more `{{.Name}}` entities.
    get:
      summary: List {{.SnakeName}}s.
      tags:
        - {{$.PascalName}}CatalogService
      parameters:
        - name: name
          description: Filter by name using SQL LIKE pattern matching.
          schema:
            type: string
          in: query
          required: false
        - name: q
          description: Free-form keyword search used to filter the response.
          schema:
            type: string
          in: query
          required: false
        - name: source
          description: Filter by source ID.
          schema:
            type: array
            items:
              type: string
          in: query
          required: false
        - name: sourceLabel
          description: |-
            Filter by the label associated with the source. Multiple
            values can be separated by commas. If one of the values is the
            string `null`, then entities from every source without a label will
            be returned.
          schema:
            type: array
            items:
              type: string
          in: query
          required: false
        - $ref: "#/components/parameters/filterQuery"
        - $ref: "#/components/parameters/pageSize"
        - $ref: "#/components/parameters/orderBy"
        - $ref: "#/components/parameters/sortOrder"
        - $ref: "#/components/parameters/nextPageToken"
      responses:
        "200":
          $ref: "#/components/responses/{{.Name}}ListResponse"
        "400":
          $ref: "#/components/responses/BadRequest"
        "401":
          $ref: "#/components/responses/Unauthorized"
        "500":
          $ref: "#/components/responses/InternalServerError"
      operationId: find{{.Name}}s

  {{$.BasePath}}/{{.SnakeName}}s/filter_options:
    description: Lists options for `filterQuery` when listing {{.SnakeName}}s.
    get:
      summary: Lists fields and values that can be used in `filterQuery` on the list {{.SnakeName}}s endpoint.
      tags:
        - {{$.PascalName}}CatalogService
      responses:
        "200":
          $ref: "#/components/responses/FilterOptionsResponse"
        "400":
          $ref: "#/components/responses/BadRequest"
        "401":
          $ref: "#/components/responses/Unauthorized"
        "500":
          $ref: "#/components/responses/InternalServerError"
      operationId: find{{.Name}}sFilterOptions

  {{$.BasePath}}/{{.SnakeName}}s/{id}:
    description: >-
      The REST endpoint/path used to get a single `{{.Name}}` entity.
    get:
      summary: Get a {{.SnakeName}} by ID.
      tags:
        - {{$.PascalName}}CatalogService
      parameters:
        - name: id
          description: The unique identifier of the entity.
          schema:
            type: string
          in: path
          required: true
      responses:
        "200":
          $ref: "#/components/responses/{{.Name}}Response"
        "401":
          $ref: "#/components/responses/Unauthorized"
        "404":
          $ref: "#/components/responses/NotFound"
        "500":
          $ref: "#/components/responses/InternalServerError"
      operationId: get{{.Name}}
{{- end}}

# Parameters (pageSize, orderBy, filterQuery, sortOrder, nextPageToken) and shared
# responses (BadRequest, FilterOptionsResponse, etc.) are provided by lib/common.yaml
# and catalog.yaml during spec assembly. Only plugin-specific schemas and responses
# are defined here.
components:
  schemas:
{{- range .ContextEntities}}
    {{.Name}}:
      description: A {{.SnakeName}} entity in the catalog.
      allOf:
        - $ref: "#/components/schemas/BaseResource"
        - type: object
          properties:
            source_id:
              type: string
              description: Catalog source that provides this entity.
            # TODO: Add entity-specific fields here.

    {{.Name}}List:
      description: A list of {{.SnakeName}} entities.
      allOf:
        - type: object
          properties:
            items:
              description: Array of `{{.Name}}` entities.
              type: array
              items:
                $ref: "#/components/schemas/{{.Name}}"
          required:
            - items
        - $ref: "#/components/schemas/BaseResourceList"
{{- end}}

  responses:
{{- range .ContextEntities}}
    {{.Name}}ListResponse:
      description: A list of {{.SnakeName}} entities.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/{{.Name}}List"
    {{.Name}}Response:
      description: A single {{.SnakeName}} entity.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/{{.Name}}"
{{- end}}
